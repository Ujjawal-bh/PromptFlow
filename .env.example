# Prompt Manager — local & production template
# Copy to `.env` and adjust values.

# PostgreSQL (local example — DB name: promptmanger per project notes)
DATABASE_URL="postgresql://postgres:redhat@localhost:5432/promptmanger?schema=public"

# Auth.js / NextAuth — required for sessions (use one; AUTH_SECRET is preferred)
AUTH_SECRET="replace-with-long-random-string"
# NEXTAUTH_SECRET can match AUTH_SECRET if you prefer the legacy name
NEXTAUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Public app URL (used for absolute links in emails later; optional for MVP)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
